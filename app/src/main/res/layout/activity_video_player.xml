<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/player_root" android:layout_width="match_parent"
    android:layout_height="match_parent" android:background="@color/background">
    <LinearLayout android:id="@+id/player_content"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical">
        <LinearLayout android:id="@+id/player_toolbar"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:background="@color/surface" android:gravity="center_vertical"
            android:orientation="horizontal" android:paddingHorizontal="8dp">
            <Button android:id="@+id/player_back" style="?android:attr/borderlessButtonStyle"
                android:layout_width="64dp" android:layout_height="match_parent"
                android:text="뒤로" android:textAllCaps="false" />
            <TextView android:id="@+id/player_toolbar_title" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:ellipsize="end" android:maxLines="1" android:paddingEnd="12dp"
                android:text="다운로드 영상" android:textColor="@color/text_primary"
                android:textSize="16sp" android:textStyle="bold" />
        </LinearLayout>
        <FrameLayout android:id="@+id/player_stage" android:layout_width="match_parent"
            android:layout_height="220dp" android:background="#000000"
            android:clickable="true" android:focusable="true">
            <VideoView android:id="@+id/video_player" android:layout_width="match_parent"
                android:layout_height="match_parent" android:layout_gravity="center" />
            <ProgressBar android:id="@+id/player_loading" android:layout_width="48dp"
                android:layout_height="48dp" android:layout_gravity="center"
                android:indeterminateTint="#FFFFFF" />
            <LinearLayout android:id="@+id/player_controls"
                android:layout_width="match_parent" android:layout_height="56dp"
                android:layout_gravity="bottom" android:background="#B3000000"
                android:gravity="center_vertical" android:orientation="horizontal"
                android:paddingHorizontal="6dp">
                <ImageButton android:id="@+id/player_play_pause"
                    android:layout_width="48dp" android:layout_height="48dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:contentDescription="재생" android:padding="12dp"
                    android:src="@drawable/ic_player_pause" />
                <TextView android:id="@+id/player_position" android:layout_width="84dp"
                    android:layout_height="wrap_content" android:gravity="center"
                    android:text="00:00 / 00:00" android:textColor="#FFFFFF"
                    android:textSize="11sp" />
                <SeekBar android:id="@+id/player_seek" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:max="1000" android:progressTint="#FFFFFF"
                    android:thumbTint="#FFFFFF" />
                <ImageButton android:id="@+id/player_fullscreen"
                    android:layout_width="48dp" android:layout_height="48dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:contentDescription="전체화면" android:padding="12dp"
                    android:src="@drawable/ic_player_fullscreen" />
            </LinearLayout>
        </FrameLayout>
        <ScrollView android:id="@+id/player_details_scroll"
            android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" android:background="@color/background"
            android:fillViewport="true">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:background="@drawable/bg_player_info_card" android:elevation="1dp"
                    android:orientation="vertical" android:padding="16dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:gravity="center_vertical" android:orientation="horizontal">
                        <ImageView android:id="@+id/player_thumbnail" android:layout_width="112dp"
                            android:layout_height="78dp" android:background="@color/divider"
                            android:contentDescription="영상 썸네일" android:scaleType="centerCrop" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_marginStart="14dp" android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:id="@+id/player_title" android:layout_width="match_parent"
                                android:layout_height="wrap_content" android:maxLines="3"
                                android:textColor="@color/text_primary" android:textSize="18sp"
                                android:textStyle="bold" />
                            <TextView android:id="@+id/player_file_meta" android:layout_width="match_parent"
                                android:layout_height="wrap_content" android:layout_marginTop="7dp"
                                android:textColor="@color/text_secondary" android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:layout_marginTop="16dp" android:background="@color/divider" />
                    <LinearLayout android:id="@+id/player_actors_section"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="15dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="출연" android:textColor="@color/text_secondary"
                            android:textSize="12sp" android:textStyle="bold" />
                        <TextView android:id="@+id/player_actors" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:layout_marginTop="5dp"
                            android:textColor="@color/text_primary" android:textSize="15sp" />
                    </LinearLayout>
                    <LinearLayout android:id="@+id/player_tags_section"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="16dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="태그" android:textColor="@color/text_secondary"
                            android:textSize="12sp" android:textStyle="bold" />
                        <HorizontalScrollView android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:layout_marginTop="7dp"
                            android:scrollbars="none">
                            <LinearLayout android:id="@+id/player_tag_list"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:orientation="horizontal" />
                        </HorizontalScrollView>
                    </LinearLayout>
                    <LinearLayout android:id="@+id/player_description_section"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="16dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="영상 설명" android:textColor="@color/text_secondary"
                            android:textSize="12sp" android:textStyle="bold" />
                        <TextView android:id="@+id/player_description"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:layout_marginTop="6dp" android:lineSpacingExtra="3dp"
                            android:textColor="@color/text_primary" android:textSize="14sp" />
                    </LinearLayout>
                    <TextView android:id="@+id/player_no_details" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:layout_marginTop="15dp"
                        android:text="이전에 받은 영상이라 상세 정보가 없습니다. 새로 다운로드하는 영상부터 썸네일·출연·태그·설명이 함께 저장됩니다."
                        android:textColor="@color/text_secondary" android:textSize="13sp"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</FrameLayout>