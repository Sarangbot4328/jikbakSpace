<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginBottom="10dp" android:background="@color/surface"
    android:clickable="true" android:focusable="true" android:foreground="?attr/selectableItemBackground"
    android:orientation="horizontal" android:padding="12dp">
    <ImageView android:id="@+id/thumbnail" android:layout_width="82dp" android:layout_height="106dp"
        android:background="@color/divider" android:contentDescription="작품 썸네일" android:scaleType="centerCrop" />
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_marginStart="14dp" android:layout_weight="1"
        android:orientation="vertical">
        <TextView android:id="@+id/title" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:ellipsize="end" android:maxLines="3" android:textColor="@color/text_primary" android:textSize="17sp" android:textStyle="bold" />
        <TextView android:id="@+id/tags" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="7dp" android:maxLines="2" android:textColor="@color/green_dark" android:textSize="12sp" />
        <TextView android:id="@+id/count" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="9dp" android:textColor="@color/text_secondary" android:textSize="13sp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="8dp" android:orientation="horizontal">
            <Button android:id="@+id/resume" android:layout_width="0dp" android:layout_height="40dp"
                android:layout_weight="1" android:text="이어받기" android:textAllCaps="false"
                android:textColor="@color/green_dark" />
            <Button android:id="@+id/delete" android:layout_width="0dp" android:layout_height="40dp"
                android:layout_marginStart="8dp" android:layout_weight="1"
                android:text="삭제" android:textAllCaps="false" android:textColor="#C62828" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
