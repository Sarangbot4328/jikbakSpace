<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/background" android:orientation="vertical">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/surface" android:gravity="center_vertical"
        android:orientation="horizontal" android:padding="16dp">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="다운로드" android:textColor="@color/text_primary"
                android:textSize="22sp" android:textStyle="bold" />
            <TextView android:id="@+id/video_status" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:layout_marginTop="3dp"
                android:text="저장한 AVSee 영상을 볼 수 있습니다"
                android:textColor="@color/text_secondary" android:textSize="12sp" />
        </LinearLayout>
        <Button android:id="@+id/refresh_videos" android:layout_width="wrap_content"
            android:layout_height="42dp" android:text="새로고침" android:textAllCaps="false" />
    </LinearLayout>
    <LinearLayout
        android:id="@+id/download_progress_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="12dp"
        android:layout_marginTop="8dp"
        android:layout_marginRight="12dp"
        android:background="@color/surface"
        android:elevation="2dp"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone">
        <TextView
            android:id="@+id/download_progress_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="다운로드 중"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/download_progress_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="다운로드 준비 중…"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />
        <ProgressBar
            android:id="@+id/download_progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="8dp"
            android:indeterminate="true"
            android:max="100"
            android:progress="0"
            android:progressTint="@color/green" />
    </LinearLayout>
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/video_swipe" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1">
        <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/video_list" android:layout_width="match_parent"
                android:layout_height="match_parent" android:clipToPadding="false"
                android:paddingLeft="12dp" android:paddingTop="12dp"
                android:paddingRight="12dp" android:paddingBottom="24dp" />
            <TextView android:id="@+id/video_empty" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:layout_gravity="center"
                android:gravity="center"
                android:text="아직 다운로드한 영상이 없습니다\nAVSee 탭에서 영상을 재생한 뒤 다운로드하세요"
                android:textColor="@color/text_secondary" android:textSize="15sp" />
        </FrameLayout>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
</LinearLayout>
