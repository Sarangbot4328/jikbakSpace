<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginBottom="10dp" android:background="@color/surface"
    android:clickable="true" android:focusable="true" android:orientation="horizontal"
    android:padding="12dp">
    <CheckBox
        android:id="@+id/select_video"
        android:layout_width="40dp"
        android:layout_height="82dp"
        android:buttonTint="@color/green"
        android:contentDescription="내보낼 영상 선택"
        android:gravity="center"
        android:visibility="gone" />
    <ImageView android:id="@+id/video_thumbnail" android:layout_width="116dp"
        android:layout_height="82dp" android:background="@color/divider"
        android:contentDescription="영상 썸네일" android:scaleType="centerCrop" />
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/video_title" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:ellipsize="end" android:maxLines="2"
            android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold" />
        <TextView android:id="@+id/video_meta" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginTop="5dp"
            android:ellipsize="end" android:maxLines="1" android:textColor="@color/text_secondary"
            android:textSize="12sp" />
        <TextView android:id="@+id/video_detail" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginTop="4dp"
            android:ellipsize="end" android:maxLines="1" android:textColor="@color/text_secondary"
            android:textSize="12sp" />
        <LinearLayout android:id="@+id/video_actions"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="7dp" android:gravity="end" android:orientation="horizontal">
            <Button android:id="@+id/play_video" android:layout_width="72dp"
                android:layout_height="38dp" android:text="재생" android:textAllCaps="false" />
            <Button android:id="@+id/delete_video" android:layout_width="72dp"
                android:layout_height="38dp" android:layout_marginStart="6dp"
                android:text="삭제" android:textAllCaps="false" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
