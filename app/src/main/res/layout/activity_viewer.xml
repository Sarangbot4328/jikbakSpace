<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:id="@+id/viewer_root"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#111111" android:orientation="vertical">
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:background="#EE111111" android:gravity="center_vertical" android:paddingHorizontal="8dp">
        <Button android:id="@+id/back" style="?android:attr/borderlessButtonStyle"
            android:layout_width="48dp" android:layout_height="match_parent" android:text="‹" android:textColor="#FFFFFF" android:textSize="30sp" />
        <TextView android:id="@+id/title" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:ellipsize="end" android:maxLines="1" android:textColor="#FFFFFF" android:textStyle="bold" />
        <Button android:id="@+id/previous" style="?android:attr/borderlessButtonStyle"
            android:layout_width="48dp" android:layout_height="match_parent" android:text="이전" android:textColor="#FFFFFF" android:textSize="12sp" />
        <Button android:id="@+id/next" style="?android:attr/borderlessButtonStyle"
            android:layout_width="48dp" android:layout_height="match_parent" android:text="다음" android:textColor="#FFFFFF" android:textSize="12sp" />
    </LinearLayout>
    <WebView android:id="@+id/image_list"
        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />
</LinearLayout>
