<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="64dp"
    android:layout_marginBottom="1dp" android:background="@color/surface"
    android:clickable="true" android:focusable="true" android:foreground="?attr/selectableItemBackground"
    android:gravity="center_vertical" android:orientation="horizontal" android:paddingHorizontal="16dp">
    <TextView android:id="@+id/number" android:layout_width="62dp" android:layout_height="wrap_content"
        android:textColor="@color/green_dark" android:textStyle="bold" />
    <TextView android:id="@+id/title" android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:ellipsize="end" android:maxLines="1" android:textColor="@color/text_primary" />
    <TextView android:id="@+id/count" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textColor="@color/text_secondary" android:textSize="12sp" />
</LinearLayout>
